---
import Link from '@/icons/Link.astro';

import me from '@/../public/me.webp';

const {
  card: { title, descripcion, tecnologias },
} = Astro.props;
---

<!-- TODO: VER SI HAGO FUNCIONAR EL IMPORT DE LA IMAGEN -->
<div class="container">
  <article>
    <img src="../../public/me.webp" alt="" />

    <div class="info">
      <header>
        <h3>{title}</h3>
        <p>{descripcion}</p>
        <div class="items">
          {
            tecnologias.map((tecnologia) => {
              return <span class="item">{tecnologia}</span>;
            })
          }
        </div>
      </header>

      <div class="link">
        <p>Ver más</p>
        <Link width={16} height={16} />
      </div>
    </div>
  </article>
</div>

<style>
  article {
    display: flex;
    gap: 2rem;
    border: 1px solid var(--primary-color-900);
    border-radius: 16px;
    padding: 20px;
    transition: 0.5s;

    &:hover {
      background: var(--primary-color-950);
    }
  }
  img {
    height: 296px;
    border-radius: 12px;
  }
  .info {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
  }
  .items {
    display: flex;
    flex-wrap: wrap;
    row-gap: 16px;
    column-gap: 24px;
  }
  .item {
    border: 1px solid var(--secundary-color-800);
    color: var(--secundary-color-600);
    border-radius: 4px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 600;
    transition: 0.5s;

    &:hover {
      color: var(--secundary-color-500);
    }
  }
  header {
    display: flex;
    flex-direction: column;
    gap: 20px;

    p {
      line-height: 24px;
    }
  }
  .link {
    display: flex;
    /* justify-content: center; */
    align-items: center;
    gap: 10px;
    padding: 4px 16px;
    font-weight: 500;
    color: var(--secundary-color-950, #000);
    background: linear-gradient(
      267deg,
      var(--accent-color, #0ca2e3) 10%,
      var(--secundary-color-500, #09de5c) 100%
    );
    border-radius: 6px;
    width: fit-content;
    transition: 0.6s;

    &:hover {
      gap: 16px;
    }
  }

  @media (width <= 768px) {
    .container {
      display: flex;
      justify-content: center;
    }
    article {
      flex-direction: column;
      align-items: center;
      max-width: 500px;
    }

    img {
      width: 100%;
      object-fit: cover;
    }
  }
</style>
