---
import Section from '@/components/Section.astro';
---

<Section>
  <h2 id="educacion">Educación</h2>
  <div class="container">
    <div>
      <div class="info">
        <p>Fundación Universitaria Católica del Norte</p>
        <p>Grado en Ingeniería Informática</p>
      </div>
      <time datetime=""><span>2022 - Actual</span></time>
    </div>
    <div>
      <div class="info">
        <p>Google</p>
        <p>Curso de Ciberseguridad de Google</p>
      </div>
      <time datetime=""><span>2024</span></time>
    </div>
    <div>
      <div class="info">
        <p>Fundación Universitaria Católica del Norte</p>
        <p>Diplomado en Seguridad Informática</p>
      </div>
      <time datetime=""><span>2022</span></time>
    </div>
    <div>
      <div class="info">
        <p>Fundación Universitaria Católica del Norte</p>
        <p>Tecnología en Desarrollo de Software</p>
      </div>
      <time datetime=""><span>2019 - 2022</span></time>
    </div>
  </div>
</Section>

<style>
  h2 {
    padding-bottom: 1.5rem;
  }

  .container {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    div {
      display: flex;
      justify-content: space-between;
    }
  }

  .info {
    display: flex;
    flex-direction: column;

    p {
      margin: 2px;
    }
  }

  .info p:nth-child(1) {
    color: var(--parrafo-education);
  }

  time {
    color: var(--primary-color-400);

    span {
      color: var(--secundary-color-400);
      background: var(--secundary-color-950);
      border-radius: 50px;
      padding: 2px 12px;
      font-size: 14px;
    }
  }

  @media (width <= 768px) {
    time {
      min-width: 120px;
      text-align: right;
    }

    .container div {
      column-gap: 1.8rem;
    }

    span {
      font-size: 14px;
    }
  }
</style>
