---
import Section from '@/components/Section.astro';
import Contacto from '../Contacto.astro';
---

<Section>
  <div class="container">
    <figure>
      <img src="/portfolio-marisol-henao/me.webp" alt="Foto de Marisol Henao" />
    </figure>

    <div class="info">
      <h1>Marisol Henao</h1>
      <h2>
        Apasionada por el <span>Desarrollo Web</span> y la <span
          >Ciberseguridad</span
        >
      </h2>

      <div class="ubicacion-container">
        <div class="bandera">
          <div class="franja yellow"></div>
          <div class="franja blue"></div>
          <div class="franja red"></div>
        </div>
        <p class="ubicacionText">Medellín - Colombia</p>
      </div>

      <div class="contacto">
        <Contacto />
      </div>
    </div>
  </div>
</Section>

<style>
  .container {
    display: flex;
    gap: 1rem;
    height: 70vh;
    align-items: center;
  }
  figure {
    width: 379px;
    aspect-ratio: 1 / 1;

    img {
      width: 100%;
      border-radius: 50%;
    }
  }
  .info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  h1 {
    font-weight: 700;
    background: linear-gradient(
      267deg,
      var(--hero-color-h1, #0ca2e3) 10%,
      var(--secundary-color-500, #09de5c) 100%
    );
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  h2 {
    line-height: 3rem;
  }
  h2 span {
    color: var(--hero-color);
  }
  /* bandera */
  .ubicacion-container {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .ubicacion-container p {
    width: 100%;
  }
  .bandera {
    width: 40px;
    height: 20px;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--primary-color-100, #fff);
  }
  .franja {
    flex: 1;
    width: 100%;
  }
  .yellow {
    background-color: #ffd700;
    flex: 2;
  }
  .blue {
    background-color: #0033a0;
  }
  .red {
    background-color: #c8102e;
  }
  /* Fin: bandera */
  .contacto {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0.4rem 0;
  } 
  
  @media (width <= 768px) {
    .contacto {
      flex-wrap: wrap;
    }
    .container {
      flex-direction: column;
      height: auto;
      align-items: center;
      justify-content: center;
    }
    .info {
      align-items: center;
    }
    h1, h2 {
        text-align: center;
    }
    figure {
      width: 300px;
    }
  }
</style>
